{
  "name": "ttb-label-verifier-backend",
  "version": "0.1.0",
  "description": "TTB Label Verifier - AWS SAM backend (API Gateway + Lambda)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "sam build",
    "start": "sam build && sam local start-api --port 3000 --env-vars env.local.json",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests --coverage",
    "deploy": "sam deploy --guided"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true
  },
  "keywords": [
    "aws",
    "lambda",
    "sam",
    "serverless"
  ],
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "esbuild": "^0.27.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
