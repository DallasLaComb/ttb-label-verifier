# Copy this file to .env and fill in real values for local development.
# .env is gitignored - never commit real API keys.

# AI vision provider used by the backend's VerifyLabelFunction to extract
# label fields from uploaded images (e.g. "anthropic", "openai", "gemini").
AI_API_PROVIDER=anthropic

# Model used for label field extraction. Claude Sonnet 4.6 was chosen for its
# vision/OCR accuracy on small print (government warnings, addresses) - at
# this volume the cost difference vs. a cheaper model is negligible.
AI_MODEL=claude-sonnet-4-6

# API key for the AI vision provider above.
AI_API_KEY=

# Frontend origin(s) allowed to call the local API (comma-separated).
ALLOWED_ORIGINS=http://localhost:4200
