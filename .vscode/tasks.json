{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Frontend: Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Install All Dependencies",
      "dependsOn": ["Backend: Install Dependencies", "Frontend: Install Dependencies"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Backend: Start Dev Server",
      "type": "shell",
      "command": "open -a Docker && echo 'Waiting for Docker...' && until docker info > /dev/null 2>&1; do sleep 1; done && echo 'Docker ready.' && grep -v '^#' \"${workspaceFolder}/.env\" | grep '=' | jq -Rn '{Parameters: ([inputs | select(length>0) | split(\"=\") | {(.[0]): (.[1:] | join(\"=\"))}] | add // {})}' > env.local.json && SAM_CLI_TELEMETRY=0 npm start",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting SAM CLI",
          "endsPattern": "Running on http"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Frontend: Start Dev Server",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Initial chunk files",
          "endsPattern": "Compiled successfully|Application bundle generation complete"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Start Full Stack",
      "dependsOn": ["Backend: Start Dev Server", "Frontend: Start Dev Server"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "install and run all tasks",
      "dependsOn": ["Install All Dependencies", "Start Full Stack"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
